# ========================
# Root .gitignore for fastapi-next-jollof
# ========================

# ========================
# Python / Backend
# ========================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# Python lib (but not cli/src/lib)
/lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Virtual environments
venv/
ENV/
env/
.venv/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# ========================
# Node.js / Frontend
# ========================

# Dependencies
node_modules/
.pnp/
.pnp.js
.yarn/install-state.gz

# Next.js
.next/
out/

# Turbopack
.turbo/

# Vercel
.vercel

# TypeScript
*.tsbuildinfo

# PWA
public/sw.js
public/workbox-*.js
public/sw.js.map
public/workbox-*.js.map

# Storybook
storybook-static/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# ESLint
.eslintcache

# ========================
# Environment & Secrets
# ========================

.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
!.env.example
!.env.test

# Secrets and credentials
*.pem
*.key
credentials.json
secrets.json
.sentryclirc

# ========================
# IDE & Editors
# ========================

.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# Local History (VS Code extension)
.history/

# ========================
# OS Generated Files
# ========================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ========================
# Logs & Databases
# ========================

*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# SQLite databases
*.db
*.sqlite3

# ========================
# Misc
# ========================

# Coverage
coverage/
.nyc_output/

# Temp files
tmp/
temp/
*.tmp
*.temp

# CLI development scripts
cli/scripts/
