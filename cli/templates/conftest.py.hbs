# =============================================================================
# SAFETY CHECK - Prevent running tests against production database
# =============================================================================
def pytest_configure(config):
    """Verify we're using a safe test database before running any tests."""
    from app.base.testing.utils import is_safe_test_db
    from app.core.config import settings

    # Check 1: Environment must be "testing"
    if settings.environment not in ("testing", "test"):
        raise RuntimeError(
            f"\n\n"
            f"{'=' * 60}\n"
            f"SAFETY ERROR: Wrong environment!\n"
            f"{'=' * 60}\n"
            f"Current environment: {settings.environment}\n"
            f"Tests must run with ENVIRONMENT=testing\n\n"
            f"Run tests with:\n"
            f"  APP_ENV_FILE=.env.test pytest\n"
            f"{'=' * 60}\n"
        )

    # Check 2: Database must be safe (SQLite or *_test)
    if not is_safe_test_db(settings.database_url):
        raise RuntimeError(
            f"\n\n"
            f"{'=' * 60}\n"
            f"SAFETY ERROR: Unsafe database!\n"
            f"{'=' * 60}\n"
            f"Database URL: {settings.database_url}\n\n"
            f"Tests require either:\n"
            f"  - SQLite database (sqlite://)\n"
            f"  - Database with 'db_test' in the name\n\n"
            f"Run tests with:\n"
            f"  APP_ENV_FILE=.env.test pytest\n"
            f"{'=' * 60}\n"
        )


# =============================================================================
# SESSION-SCOPED FIXTURES
# =============================================================================
@pytest.fixture(scope="session")
def event_loop() -> Generator:
    """Create event loop for async tests."""
    import asyncio

    loop = asyncio.get_event_loop_policy().new_event_loop()
    yield loop
    loop.close()
