# =============================================================================
# {{appName}} - Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# App Configuration
APP_NAME="{{appName}}"
APP_DESCRIPTION="A production-ready FastAPI + Next.js application"
DEBUG=true
ENVIRONMENT=development

# Database (PostgreSQL with SQLAlchemy 2.0 async)
# For Docker: postgresql+asyncpg://postgres:postgres@postgres:5432/{{dbName}}
# For local: postgresql+asyncpg://postgres:postgres@localhost:5432/{{dbName}}
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/{{dbName}}

# Supabase Auth (Required)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLIC_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Google OAuth (Optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

{{#if isNomba}}
# Payment - Nomba (Nigeria)
# Get credentials from: https://dashboard.nomba.com
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_ACCOUNT_ID=
NOMBA_WEBHOOK_SECRET=
{{/if}}
{{#if isStripe}}
# Payment - Stripe (Global)
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
{{/if}}
{{#if isPaystack}}
# Payment - Paystack (Africa)
# Get keys from: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_WEBHOOK_SECRET=
{{/if}}

{{#if isResend}}
# Email - Resend
# Get key from: https://resend.com/api-keys
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME={{appName}}
{{/if}}
{{#if isBrevo}}
# Email - Brevo
# Get key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME={{appName}}
{{/if}}

# Security (Required - generate with: openssl rand -hex 32)
SECRET_KEY=change-this-to-a-random-secret-key

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:{{frontendPort}}

# Redis (Required for rate limiting)
# For Docker: redis://redis:6379/0
# For local: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Sentry (Optional - production)
SENTRY_DSN=
