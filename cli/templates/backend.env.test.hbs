# =============================================================================
# {{appName}} - Test Environment Configuration
# =============================================================================
# This file is used for running tests with isolated settings

# Database (SQLite in-memory for tests)
DATABASE_URL=sqlite+aiosqlite:///:memory:

# Supabase Auth (Test values)
SUPABASE_URL=https://test.supabase.co
SUPABASE_PUBLIC_KEY=test-public-key
SUPABASE_SECRET_KEY=test-secret-key
SUPABASE_JWT_SECRET=test-jwt-secret

{{#if isNomba}}
# Payment - Nomba (Test)
NOMBA_CLIENT_ID=test-client-id
NOMBA_CLIENT_SECRET=test-client-secret
NOMBA_ACCOUNT_ID=test-account-id
NOMBA_WEBHOOK_SECRET=test-webhook-secret
{{/if}}
{{#if isStripe}}
# Payment - Stripe (Test)
STRIPE_SECRET_KEY=sk_test_fake
STRIPE_PUBLISHABLE_KEY=pk_test_fake
STRIPE_WEBHOOK_SECRET=whsec_test_fake
{{/if}}
{{#if isPaystack}}
# Payment - Paystack (Test)
PAYSTACK_SECRET_KEY=sk_test_fake
PAYSTACK_PUBLIC_KEY=pk_test_fake
PAYSTACK_WEBHOOK_SECRET=test-webhook-secret
{{/if}}

{{#if isResend}}
# Email - Resend (Test)
RESEND_API_KEY=re_test_key
FROM_EMAIL=test@example.com
FROM_NAME={{appName}}
{{/if}}
{{#if isBrevo}}
# Email - Brevo (Test)
BREVO_API_KEY=xkeysib_test_key
FROM_EMAIL=test@example.com
FROM_NAME={{appName}}
{{/if}}
{{#if noEmail}}
# No email provider configured
{{/if}}

# Security
SECRET_KEY=test-secret-key-for-testing-only

# Redis
REDIS_URL=redis://localhost:6379

# App
DEBUG=false
ENVIRONMENT=testing
CORS_ALLOWED_ORIGINS=http://localhost:{{frontendPort}},http://localhost:{{backendPort}}
