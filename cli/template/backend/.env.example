# =============================================================================
# FastAPI Next Jollof - Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# App Configuration
APP_NAME="Jollof App"
APP_DESCRIPTION="A production-ready FastAPI + Next.js boilerplate"
DEBUG=true
ENVIRONMENT=development  # development, staging, production

# Theme/Branding (used for emails, etc.)
PRIMARY_COLOR="#6366f1"
SECONDARY_COLOR="#ec4899"

# Database (PostgreSQL with Tortoise ORM)
DATABASE_URL=postgres://user:password@localhost:5432/jollofdb

# Supabase Auth (Required)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLIC_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Google OAuth (Optional - for social login)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Payment - Nomba (Nigeria) - TESTED
# Get credentials from: https://dashboard.nomba.com
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_ACCOUNT_ID=
NOMBA_WEBHOOK_SECRET=

# Payment - Stripe (Global) - Optional
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Payment - Paystack (Africa) - Optional
# Get keys from: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_WEBHOOK_SECRET=

# Default payment provider: nomba, paystack, stripe
DEFAULT_PAYMENT_PROVIDER=nomba

# Email - Resend (Recommended)
# Get key from: https://resend.com/api-keys
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Your App Name

# Email - Brevo (Alternative)
# Get key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...

# Default email provider: resend, brevo
DEFAULT_EMAIL_PROVIDER=resend

# Security (Required - generate a random secret)
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this

# CORS (Required - comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Redis (Required for rate limiting and caching)
REDIS_URL=redis://localhost:6379

# Sentry (Optional - production error tracking)
# Get DSN from: https://sentry.io/settings/
SENTRY_DSN=
