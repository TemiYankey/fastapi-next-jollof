{
  "name": "create-jollof-app",
  "version": "1.0.0",
  "description": "Create a full-stack FastAPI + Next.js application with authentication, payments, and more",
  "main": "dist/index.js",
  "bin": {
    "create-jollof-app": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "fastapi",
    "nextjs",
    "fullstack",
    "boilerplate",
    "supabase",
    "payments",
    "cli",
    "create-app"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "gradient-string": "^3.0.0",
    "handlebars": "^4.7.8",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^22.13.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "template"
  ]
}
